{
  "__comment": "Qwen Image Edit 2509 图像编辑工作流（4步 Lightning，UNETLoader+CLIPLoader qwen_image type）",
  "__params": {
    "EDIT_IMAGE": "load_img.image（已上传的原图文件名）",
    "INSTRUCTION": "encode.prompt（编辑指令，支持中英文，如：把衬衫改成红色）",
    "SEED": "sample.seed",
    "WIDTH": "latent.width（默认1024，需为64的倍数）",
    "HEIGHT": "latent.height（默认1024，需为64的倍数）"
  },
  "1": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "qwen_image_edit_2509_fp8_e4m3fn.safetensors", "weight_dtype": "default"}
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {"clip_name": "qwen_2.5_vl_7b_fp8_scaled.safetensors", "type": "qwen_image", "device": "default"}
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "qwen_image_vae.safetensors"}
  },
  "4": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["1", 0],
      "lora_name": "Qwen-Image-Edit-2509-Lightning-4steps-V1.0-bf16.safetensors",
      "strength_model": 1.0
    }
  },
  "5": {
    "class_type": "CFGNorm",
    "inputs": {"model": ["4", 0], "strength": 1}
  },
  "6": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {"model": ["5", 0], "shift": 3}
  },
  "7": {
    "class_type": "LoadImage",
    "inputs": {"image": "EDIT_IMAGE", "upload": "image"}
  },
  "8": {
    "class_type": "TextEncodeQwenImageEditPlus",
    "inputs": {
      "clip": ["2", 0],
      "vae": ["3", 0],
      "image1": ["7", 0],
      "prompt": "INSTRUCTION"
    }
  },
  "9": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": 1024, "height": 1024, "batch_size": 1}
  },
  "10": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["6", 0],
      "positive": ["8", 0],
      "negative": ["8", 0],
      "latent_image": ["9", 0],
      "seed": 0,
      "steps": 4,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["10", 0], "vae": ["3", 0]}
  },
  "12": {
    "class_type": "SaveImage",
    "inputs": {"images": ["11", 0], "filename_prefix": "comic_edit"}
  }
}
