{
  "__comment": "仙侠风格基础图像生成（SDXL dreamshaperXL + 仙侠LoRA），已通过 TC-02/TC-03 验证",
  "__params": {
    "POSITIVE_PROMPT": "节点2 text",
    "NEGATIVE_PROMPT": "节点3 text",
    "SEED": "节点5 seed",
    "STEPS": "节点5 steps",
    "CFG": "节点5 cfg",
    "WIDTH": "节点4 width",
    "HEIGHT": "节点4 height",
    "LORA_STRENGTH": "节点lora strength_model / strength_clip"
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {"ckpt_name": "dreamshaperXL_lightningDPMSDE.safetensors"}
  },
  "lora": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "仙侠风格.safetensors",
      "strength_model": 0.7,
      "strength_clip": 0.7
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "POSITIVE_PROMPT",
      "clip": ["lora", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "ugly, deformed, blurry, low quality, bad anatomy, watermark, text, nsfw",
      "clip": ["lora", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {"width": 768, "height": 1024, "batch_size": 1}
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["lora", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0]
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["5", 0], "vae": ["1", 2]}
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "comic_frame", "images": ["6", 0]}
  }
}
