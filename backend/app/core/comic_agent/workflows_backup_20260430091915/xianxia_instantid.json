{
  "__comment": "仙侠 InstantID 人脸保持工作流（dreamshaperXL + 仙侠LoRA + InstantID SDXL）",
  "__params": {
    "POSITIVE_PROMPT": "节点2 text",
    "NEGATIVE_PROMPT": "节点3 text",
    "FACE_IMAGE": "节点face_img image（已上传的人脸文件名）",
    "SEED": "节点5 seed",
    "FACE_WEIGHT": "节点apply_id weight（0.0~1.0，默认0.8）"
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {"ckpt_name": "dreamshaperXL_lightningDPMSDE.safetensors"}
  },
  "lora": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "仙侠风格.safetensors",
      "strength_model": 0.7,
      "strength_clip": 0.7
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "POSITIVE_PROMPT",
      "clip": ["lora", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "ugly, deformed, blurry, low quality, bad anatomy, watermark, text, nsfw",
      "clip": ["lora", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {"width": 768, "height": 1024, "batch_size": 1}
  },
  "face_analysis": {
    "class_type": "InstantIDFaceAnalysis",
    "inputs": {"provider": "CUDA"}
  },
  "instantid": {
    "class_type": "InstantIDModelLoader",
    "inputs": {"instantid_file": "ip-adapter_instant_id_sdxl.bin"}
  },
  "face_img": {
    "class_type": "LoadImage",
    "inputs": {"image": "FACE_IMAGE", "upload": "image"}
  },
  "cn": {
    "class_type": "ControlNetLoader",
    "inputs": {"control_net_name": "control_instant_id_sdxl.safetensors"}
  },
  "apply_id": {
    "class_type": "ApplyInstantID",
    "inputs": {
      "instantid": ["instantid", 0],
      "insightface": ["face_analysis", 0],
      "control_net": ["cn", 0],
      "image": ["face_img", 0],
      "model": ["lora", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "weight": 0.8,
      "start_at": 0.0,
      "end_at": 1.0
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["apply_id", 0],
      "positive": ["apply_id", 1],
      "negative": ["apply_id", 2],
      "latent_image": ["4", 0]
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["5", 0], "vae": ["1", 2]}
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "comic_face", "images": ["6", 0]}
  }
}
