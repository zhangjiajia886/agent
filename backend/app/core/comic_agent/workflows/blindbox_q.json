{
  "__comment": "盲盒Q版风格图像生成（DreamShaper_8 + blindbox_v1_mix LoRA）",
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {"ckpt_name": "DreamShaper_8_pruned.safetensors"}
  },
  "lora": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "blindbox_v1_mix.safetensors",
      "strength_model": 0.8,
      "strength_clip": 0.8
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "POSITIVE_PROMPT",
      "clip": ["lora", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "realistic, scary, ugly, deformed, text, watermark, low quality, dark, horror, nsfw",
      "clip": ["lora", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {"width": 512, "height": 512, "batch_size": 1}
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0,
      "model": ["lora", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0]
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["5", 0], "vae": ["1", 2]}
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "comic_frame", "images": ["6", 0]}
  }
}
