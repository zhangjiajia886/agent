{
  "__comment": "Z-Image Base 文生图工作流（开源最强真人图像，5s/张，CLIPLoader lumina2 type）",
  "__params": {
    "POSITIVE_PROMPT": "pos_text.text（正向提示词，推荐英文，描述画面内容）",
    "NEGATIVE_PROMPT": "neg_text.text（负向提示词，默认空）",
    "SEED": "sample.seed",
    "WIDTH": "latent.width（默认1024）",
    "HEIGHT": "latent.height（默认1024）",
    "STEPS": "sample.steps（默认25，可调10~30）",
    "CFG": "sample.cfg（默认4，Z-Image 推荐3~5）"
  },
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "z_image_bf16.safetensors",
      "weight_dtype": "default"
    }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen_3_4b.safetensors",
      "type": "lumina2",
      "device": "default"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "4": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "shift": 3
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": [
        "2",
        0
      ],
      "text": "POSITIVE_PROMPT"
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": [
        "2",
        0
      ],
      "text": ""
    }
  },
  "7": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "model": [
        "4",
        0
      ],
      "positive": [
        "5",
        0
      ],
      "negative": [
        "6",
        0
      ],
      "latent_image": [
        "7",
        0
      ],
      "seed": 0,
      "steps": 25,
      "cfg": 4.0,
      "sampler_name": "res_multistep",
      "scheduler": "simple",
      "denoise": 1.0
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "8",
        0
      ],
      "vae": [
        "3",
        0
      ]
    }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "9",
        0
      ],
      "filename_prefix": "z-image"
    }
  }
}