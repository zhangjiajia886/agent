# 应用配置
APP_NAME=TTS Application
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production
API_V1_PREFIX=/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=mysql+aiomysql://ttsapp:ttsapp123@localhost:3306/ttsapp
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis 配置
REDIS_URL=redis://:redis123456@localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fish Speech API 配置
FISH_API_URL=https://api.fish.audio
FISH_API_KEY=<FISH_API_KEY>
FISH_DEFAULT_VOICE=8a4a6717a4984a70b1413f0d7d60c434

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,flac,ogg

# 静态文件 CDN（可选）
# CDN_URL=https://cdn.example.com

# 即梦 Jimeng API 配置
JIMENG_ENABLED=false
JIMENG_AK=
JIMENG_SK=
JIMENG_REGION=cn-north-1
JIMENG_HOST=visual.volcengineapi.com
JIMENG_TIMEOUT=300
JIMENG_DEFAULT_WIDTH=768
JIMENG_DEFAULT_HEIGHT=1024
JIMENG_LEGACY_REQ_KEY=jimeng_high_aes_general_v21_L

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Elasticsearch 配置（可选）
# ELASTICSEARCH_URL=http://localhost:9200

# Milvus 配置（可选）
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# OpenAI 配置（RAG 扩展）
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Celery 配置（可选）
# CELERY_BROKER_URL=redis://:redis123456@localhost:6379/1
# CELERY_RESULT_BACKEND=redis://:redis123456@localhost:6379/2
